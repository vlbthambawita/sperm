# ============================================================
# Labelbox → YOLO Exporter — Environment Configuration
# ============================================================

# ------ Required -----------------------------------------------
LABELBOX_API_KEY=your_labelbox_api_key_here
LABELBOX_PROJECT_ID=your_project_id_here

# ------ Output paths -------------------------------------------
OUTPUT_DIR=./labelbox_export      # root folder for the dataset
IMAGE_SUBDIR=images               # subfolder name for images
LABEL_SUBDIR=labels               # subfolder name for YOLO .txt files

# ------ Dataset splitting (optional) ---------------------------
# Comma-separated train/val/test ratios that must sum to 1.0
# Comment out or leave empty to skip splitting (all → 'all/' folder)
SPLIT_RATIOS=0.8,0.1,0.1

# ------ Performance --------------------------------------------
DOWNLOAD_WORKERS=4                # parallel download threads

# ------ Behaviour ----------------------------------------------
SKIP_UNLABELED=true               # skip images with zero bounding-box annotations
