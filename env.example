# Labelbox Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Labelbox API Key - Get this from your Labelbox account settings
LABELBOX_API_KEY=your_labelbox_api_key_here

# Project Configuration
PROJECT_ID=your_project_id_here

# Data Paths (adjust to your local setup)
DATA_FOLDER=/path/to/your/data/folder

# Optional Configuration
DATASET_NAME=Sperm YOLO Dataset
BATCH_SIZE=100
IMPORT_MODE=MAL
SKIP_UNLABELED=False
CHUNK_SIZE=2000

# Tool Configuration
YOLO_CLASS_MAPPING={"0": "sperm"}
TOOL_NAME=sperm

# Global Key Configuration (to avoid duplicates)
GLOBAL_KEY_PREFIX=sperm_v2
